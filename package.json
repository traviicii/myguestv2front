{
  "name": "myguestv2",
  "version": "2.0.0-rc.17",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:lan": "node scripts/dev.mjs --lan",
    "dev:clean": "node scripts/dev.mjs --clear",
    "ios:rebuild": "node scripts/ios-rebuild.mjs",
    "ios:rebuild:clean": "node scripts/ios-rebuild.mjs --clean",
    "android": "expo run:android",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "typecheck": "npx tsc --noEmit",
    "lint": "npx eslint . --ext .js,.ts,.tsx",
    "audit:ui": "node scripts/ui-consistency-audit.mjs",
    "test": "npx playwright test",
    "test:smoke": "EXPO_PUBLIC_USE_MOCK_DATA=true npx playwright test tests/export.test.ts tests/mock-source.test.ts tests/mock-overview.spec.ts tests/clients-and-appointments.spec.ts tests/appointment-date-picker.test.ts tests/studio-store.test.ts tests/overview-store.test.ts tests/overview-model-utils.test.ts tests/settings-model-utils.test.ts tests/appointment-form-utils.test.ts tests/edit-appointment-model-utils.test.ts tests/appointment-api-payloads.test.ts tests/appointment-api-mappers.test.ts tests/color-chart-api-payloads.test.ts tests/color-chart-api-mappers.test.ts tests/color-chart-edit-model-utils.test.ts tests/sortable-grid-utils.test.ts tests/ambient-backdrop-utils.test.ts tests/onboarding-model-utils.test.ts tests/appointment-client-picker-model-utils.test.ts tests/new-appointment-model-utils.test.ts tests/settings-service-management-utils.test.ts tests/quick-log-model-utils.test.ts tests/new-client-form-utils.test.ts",
    "test:visual-theme-matrix": "npx playwright test tests/visual-theme-matrix.spec.ts",
    "upgrade:tamagui": "npx npm-check-updates -u '*tamagui*' '@tamagui/*' && npm install",
    "postinstall": "node scripts/patch-expo-crypto-ios.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.0.14",
    "@tamagui/config": "2.0.0-rc.17",
    "@tamagui/lucide-icons": "2.0.0-rc.17",
    "@tamagui/toast": "2.0.0-rc.17",
    "@tanstack/react-query": "^5.0.0",
    "babel-preset-expo": "~54.0.0",
    "burnt": "^0.12.2",
    "expo": "^54.0.23",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.9",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.9",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.9",
    "firebase": "^11.10.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tamagui": "2.0.0-rc.17",
    "zeego": "^1.10.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@playwright/test": "^1.49.1",
    "@tamagui/babel-plugin": "2.0.0-rc.17",
    "@types/react": "~19.1.10",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^9.2.0",
    "react-refresh": "^0.14.2",
    "serve": "^14.2.5",
    "typescript": "~5.9.2"
  },
  "packageManager": "npm@10.9.2"
}
